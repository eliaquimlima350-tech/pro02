def tabuada(numero, limite=10):
    print(f"Tabuada do {numero}:")
    for i in range(1, limite + 1):
        print(f"{numero} x {i} = {numero * i}")
try:
    numero = int(input("Digite um número inteiro: "))
    limite = int(input("Digite até qual número deseja ver a tabuada: "))
    tabuada(numero, limite)
except ValueError:
    print("Entrada inválida! Por favor, digite apenas números inteiros.")

def converter_temperatura(valor, escala_origem):

    escala = escala_origem.lower()

    # Converte para Celsius
    if escala == "celsius":
        celsius = valor
    elif escala == "fahrenheit":
        celsius = (valor - 32) * 5/9
    elif escala == "kelvin":
        celsius = valor - 273.15
    else:
        return "Escala inválida!"

    # Responsavel pela alidação do zero absoluto
    if celsius < -273.15:
        return "Valor abaixo do zero absoluto! Inválido."


    fahrenheit = (celsius * 9/5) + 32
    kelvin = celsius + 273.15

    return f"Celsius: {celsius:.2f}, Fahrenheit: {fahrenheit:.2f}, Kelvin: {kelvin:.2f}"

valor = float(input("Digite o valor da temperatura: "))
escala = input("Digite a escala de origem (Celsius, Fahrenheit ou Kelvin): ")

print(converter_temperatura(valor, escala))
