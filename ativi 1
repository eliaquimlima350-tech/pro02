from rich.console import Console # responsavel pelas cores
from rich.table import Table # cria tabela

console = Console() # responsavel por cria objeto para a saida

def quadrante(x, y):
    if x == 0 and y == 0: return "zero"
    if x == 0: return "Eixo Y"
    if y == 0: return "Eixo X"
    if x > 0 and y > 0: return "Q1"
    if x < 0 and y > 0: return "Q2"
    if x < 0 and y < 0: return "Q3"
    return "Q4"

# responsavel pelas cores para cada resultado
cores = {
    "Q1": "green",
    "Q2": "blue",
    "Q3": "red",
    "Q4": "yellow",
    "zero": "magenta",
    "Eixo X": "cyan",
    "Eixo Y": "cyan"
}

# entrada de dados
x, y = 0, 0 # Inicializa x e y para evitar NameError caso a entrada seja inválida
try:
    x = int(input("Digite x: "))
    y = int(input("Digite y: "))
except ValueError:
    print("Entrada inválida, digite apenas números.")
    # x e y manterão os valores padrão (0,0) neste caso

resultado = quadrante(x, y)

# Criando tabela com cor dinâmica
table = Table(title=f"Resultado da Análise do Ponto ({x}, {y})") # Indentação corrigida

table.add_column("Coordenadas", justify="center", style="bold cyan")
table.add_column("Localização", justify="center", style=cores[resultado])

table.add_row(f"({x}, {y})", resultado)

console.print(table)

